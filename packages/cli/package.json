	},
	"dependencies": {
		"@hono/node-server": "^1.13.0",
		"commander": "^12.1.0",
		"hono": "^4.6.0",
		"open": "^10.1.0"
	},
	"devDependencies": {
		"@dynascope/api": "*",
		"@types/node": "^22.0.0",
		"tsup": "^8.3.0",
		"tsx": "^4.19.0"
	}
}
