{
	"name": "dynascope",
	"version": "0.1.4",
	"description": "A web-based management interface for Amazon DynamoDB",
	"type": "module",
	"license": "MIT",
	"repository": {
		"type": "git",
		"url": "https://github.com/migstopheles/dynascope.git",
		"directory": "packages/cli"
	},
	"homepage": "https://github.com/migstopheles/dynascope#readme",
	"bugs": "https://github.com/migstopheles/dynascope/issues",
	"keywords": [
		"dynamodb",
		"aws",
		"database",
		"gui",
		"admin",
		"explorer",
		"local",
		"dynamodb-local"
	],
	"bin": {
		"dynascope": "./dist/index.js"
	},
	"files": ["dist", "README.md"],
